# Example environment variables for local development
# Copy this file to scripts/.env and customize values locally (scripts/.env is gitignored)

# Option A: full SQLAlchemy URL (preferred)
# DB_URL=mssql+pyodbc://username:password@host:1433/BigFiveDB?driver=ODBC+Driver+17+for+SQL+Server

# Option B: component parts (fallback)
# Replace the placeholders below with your local values if you don't set DB_URL
DB_HOST=YOUR_HOST\\SQLEXPRESS
# e.g. MYMACHINE\\SQLEXPRESS or server.domain.com\\SQLEXPRESS
DB_NAME=BigFiveDB
DB_TRUSTED=yes
DB_DRIVER=ODBC+Driver+17+for+SQL+Server

# JDBC jar path for PySpark
JDBC_JAR=drivers/mssql-jdbc-13.2.1.jre11.jar


